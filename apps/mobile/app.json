{
  "expo": {
    "name": "Community App",
    "slug": "community-app",
    "scheme": "communityapp",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications",
      "expo-font"
    ],
    "extra": {
      "apiUrl": "${EXPO_PUBLIC_API_URL}"
    }
  }
}
